<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Luffy: Rei dos Piratas</title>
    <style>
        body { margin: 0; background: #000; color: #fff; font-family: 'Courier New', Courier, monospace; overflow: hidden; touch-action: none; }
        canvas { display: block; }
        #interface {
            position: absolute; top: 10px; left: 10px;
            background: rgba(0,0,0,0.6); padding: 10px; border-radius: 8px;
            pointer-events: none; border: 2px solid #f1c40f;
        }
        .stats { font-size: 18px; color: #f1c40f; font-weight: bold; }
    </style>
</head>
<body>
    <div id="interface">
        <div class="stats">PONTOS: <span id="score">0</span></div>
        <div class="stats">MAPA: <span id="mapaNome">Mar de East Blue</span></div>
    </div>
    <canvas id="gameCanvas"></canvas>

<script>
    const canvas = document.getElementById("gameCanvas");
    const ctx = canvas.getContext("2d");
    const scoreElement = document.getElementById("score");
    const mapaNomeElement = document.getElementById("mapaNome");

    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;

    let score = 0;
    let nivel = 1;
    let jogoAtivo = true;

    // Configurações dos Mapas (Links de imagens reais)
    const mapas = [
        "https://images6.alphacoders.com/132/1327144.png", // East Blue
        "https://wallpapercave.com/wp/wp6577312.jpg",     // Grand Line
        "https://images8.alphacoders.com/133/1331006.png"  // Wano
    ];

    const nomesMapas = ["Mar de East Blue", "Entrada da Grand Line", "País de Wano"];

    // Carregar Imagens
    const imgLuffy = new Image();
    imgLuffy.src = "https://i.pinimg.com/originals/8a/01/f4/8a01f40d42517812e95655c654d1936c.png";

    const imgFundo = new Image();
    imgFundo.src = mapas[0];

    let jogador = { x: canvas.width / 2 - 40, y: canvas.height - 120, w: 80, h: 80, speed: 10 };
    let tiros = [];
    let inimigos = [];

    // Controles
    window.addEventListener("touchmove", (e) => {
        if (!jogoAtivo) return;
        let touch = e.touches[0];
        jogador.x = touch.clientX - jogador.w / 2;
    });

    // Criar Tiro (Gomu Gomu no Pistol)
    setInterval(() => {
        if (jogoAtivo) {
            tiros.push({ x: jogador.x + jogador.w / 2 - 5, y: jogador.y, w: 10, h: 30, cor: "#f0f" });
        }
    }, 250);

    // Criar Inimigos (Marinheiros)
    function spawnInimigo() {
        if (jogoAtivo) {
            let speedInimigo = 3 + nivel;
            inimigos.push({
                x: Math.random() * (canvas.width - 60),
                y: -60,
                w: 60,
                h: 60,
                speed: speedInimigo,
                cor: nivel === 3 ? "#ffeb3b" : "#f44336" // Muda cor no mapa de Wano
            });
        }
        setTimeout(spawnInimigo, 1000 / nivel);
    }
    spawnInimigo();

    function atualizar() {
        if (!jogoAtivo) return;

        // Mudar Mapa por Pontuação
        if (score > 200 && nivel === 1) {
            nivel = 2;
            imgFundo.src = mapas[1];
            mapaNomeElement.innerText = nomesMapas[1];
        } else if (score > 500 && nivel === 2) {
            nivel = 3;
            imgFundo.src = mapas[2];
            mapaNomeElement.innerText = nomesMapas[2];
            jogador.w = 100; // Luffy fica maior (Gear 3)
            jogador.h = 100;
        }

        // Movimentar Tiros
        tiros.forEach((t, i) => {
            t.y -= 12;
            if (t.y < 0) tiros.splice(i, 1);
        });

        // Movimentar Inimigos
        inimigos.forEach((inim, i) => {
            inim.y += inim.speed;

            // Colisão com Jogador
            if (inim.y + inim.h > jogador.y && inim.x < jogador.x + jogador.w && inim.x + inim.w > jogador.x) {
                jogoAtivo = false;
                alert("DERROTADO! Você conseguiu " + score + " pontos!");
                location.reload();
            }

            // Colisão Tiro com Inimigo
            tiros.forEach((t, ti) => {
                if (t.x < inim.x + inim.w && t.x + t.w > inim.x && t.y < inim.y + inim.h) {
                    inimigos.splice(i, 1);
                    tiros.splice(ti, 1);
                    score += 10;
                    scoreElement.innerText = score;
                }
            });

            if (inim.y > canvas.height) inimigos.splice(i, 1);
        });
    }

    function desenhar() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);

        // Desenhar Fundo
        ctx.drawImage(imgFundo, 0, 0, canvas.width, canvas.height);

        // Desenhar Luffy
        ctx.drawImage(imgLuffy, jogador.x, jogador.y, jogador.w, jogador.h);

        // Desenhar Tiros
        ctx.fillStyle = "#f0f";
        tiros.forEach(t => {
            ctx.shadowBlur = 10;
            ctx.shadowColor = "#f0f";
            ctx.fillRect(t.x, t.y, t.w, t.h);
        });
        ctx.shadowBlur = 0;

        // Desenhar Inimigos
        inimigos.forEach(inim => {
            ctx.fillStyle = inim.cor;
            ctx.fillRect(inim.x, inim.y, inim.w, inim.h);
            // Desenha um "chapéu" de marinheiro simples
            ctx.fillStyle = "#fff";
            ctx.fillRect(inim.x, inim.y, inim.w, 10);
        });

        atualizar();
        requestAnimationFrame(desenhar);
    }

    imgFundo.onload = () => {
        desenhar();
    };
</script>
</body>
</html>


